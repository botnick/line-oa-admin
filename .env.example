# ============================================
# LINE OA Admin — Environment Variables
# ============================================
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
# cp .env.example .env

# === Database ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/line_oa_admin"

# === Redis ===
REDIS_URL="redis://localhost:6379/1"

# === App ===
NODE_ENV="development"
PORT=3333
LOG_LEVEL="debug"

# === Auth ===
# สร้าง secret ยาว 32+ ตัวอักษร: openssl rand -base64 32
SESSION_SECRET="change-me-to-random-string-at-least-32-chars!"
# NOTE: คนแรกที่ Login จะเป็น Super Admin อัตโนมัติ
# เพิ่ม/ลด admin ผ่านตาราง AdminUser ใน Database (ไม่ต้อง restart)

# === LINE / R2 Storage ===
# ตั้งค่าผ่าน Setup Wizard (/setup) ไม่ต้องกรอกที่นี่
