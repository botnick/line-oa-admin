{
  "name": "line-oa-admin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @line-oa/db generate",
    "db:migrate": "pnpm --filter @line-oa/db migrate:dev",
    "db:push": "pnpm --filter @line-oa/db push",
    "db:studio": "pnpm --filter @line-oa/db studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client-runtime-utils": "^7.5.0"
  }
}
